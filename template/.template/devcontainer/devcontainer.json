{
  "name": "Custom devcontainer",
  "image": "ghcr.io/craftaholic/devcontainer:latest",

  "containerUser": "dev",
  "remoteUser": "dev",
  "updateRemoteUserUID": false,

  "runArgs": [
//    "--env-file", ".env"
  ],

  "containerEnv": {
    "DOCKER_TLS_CERTDIR": "",
  },

  "remoteEnv": {
    "AWS_PAGER": "" // This is for no pager requires for aws cli
//    "AWS_BEARER_TOKEN_BEDROCK": "${localEnv:AWS_BEARER_TOKEN_BEDROCK}"
  },

  "mounts": [
    // Using variables
    "source=${localEnv:HOME}/.config/opencode,target=/home/dev/.config/opencode,type=bind,readonly",
    "source=${localEnv:HOME}/.config/tc-tymekit,target=/home/dev/.config/tc-tymekit,type=bind,readonly",
    "source=${localWorkspaceFolder}/.devcontainer/aws-generated/credentials,target=/home/dev/.aws/credentials,type=bind,consistency=cached"
  ],

  "forwardPorts": []
}
