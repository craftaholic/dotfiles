# ========================================
# HIGH CVEs - System Libraries (Debian)
# ========================================
# Status: Debian stable maintainers explicitly marked "no DSA" (no backport planned)
# All fixes available only in sid/unstable, not in stable-slim (bookworm)

# CVE-2026-25210: libexpat1 2.7.1-2
# Reason: Integer overflow in buffer reallocation - no fix in Debian stable
# Fixed in: sid 2.7.5-1 (unstable only)
# Risk: High (potential RCE), but requires parsing untrusted XML
# Status: Awaiting Debian stable backport (marked "no DSA")
CVE-2026-25210

# CVE-2026-27135: libnghttp2-14 1.64.0-1.1  
# Reason: HTTP/2 DoS via malformed frames - no fix in Debian stable
# Fixed in: sid 1.68.1-1 (unstable only)
# Risk: Medium (DoS only, requires malformed HTTP/2 after session termination)
# Status: Awaiting Debian stable backport (marked "no DSA")
CVE-2026-27135

# CVE-2026-29111: libsystemd0/libudev1 257.9-1~deb13u1
# Reason: IPC API vulnerability - no fix in Debian stable
# Fixed in: sid 260.1-1 (unstable only)
# Risk: Medium (requires systemd as PID 1, rare in containers)
# Status: Awaiting Debian stable backport (marked "no DSA")
CVE-2026-29111

# CVE-2025-69720: libtinfo6 6.5+20250216-2
# Reason: Buffer overflow in infocmp tool - no fix in Debian stable  
# Fixed in: sid 6.6+20251231-1 (unstable only)
# Risk: Low (affects CLI tool `infocmp`, not library runtime)
# Status: Debian marked as "postponed"
CVE-2025-69720

