{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "minimumReleaseAge": "30 days",
  "digest": {
    "enabled": true,
    "automerge": false
  },
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security", "vulnerability"]
  },
  "dependencyDashboard": true,
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "separateMajorMinor": true,
  "internalChecksFilter": "strict",
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Neovim plugin commits with explicit branch comment",
      "fileMatch": [
        "^nvim/.config/nvim/lua/.+\\.lua$"
      ],
      "matchStrings": [
        "-- renovate: branch=(?<currentValue>\\S+)\\s*\\n\\s*[\"'](?<depName>[^/]+/[^\"']+)[\"'],\\s*\\n\\s*commit\\s*=\\s*[\"'](?<currentDigest>[a-f0-9]{40})[\"']"
      ],
      "datasourceTemplate": "github-digest"
    },
    {
      "customType": "regex",
      "description": "Update Neovim plugin commits (default: master branch)",
      "fileMatch": [
        "^nvim/.config/nvim/lua/.+\\.lua$"
      ],
      "matchStrings": [
        "return \\{\\s*\\n\\s*[\"'](?<depName>[^/]+/[^\"']+)[\"'],\\s*\\n\\s*commit\\s*=\\s*[\"'](?<currentDigest>[a-f0-9]{40})[\"']"
      ],
      "datasourceTemplate": "github-digest",
      "currentValueTemplate": "master"
    },
    {
      "customType": "regex",
      "description": "Update Debian apt packages in Dockerfile",
      "fileMatch": [
        "^Dockerfile$"
      ],
      "matchStrings": [
        "ARG\\s+(?<depName>[A-Z_]+)=(?<currentValue>[^\\s\\\\]+)"
      ],
      "datasourceTemplate": "debian",
      "versioningTemplate": "loose"
    },
    {
      "customType": "regex",
      "description": "Update GitHub release binaries in Dockerfile",
      "fileMatch": [
        "^Dockerfile$"
      ],
      "matchStrings": [
        "ARG\\s+MISE_VERSION=(?<currentValue>[^\\s\\\\]+)"
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "jdx/mise",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    }
  ],
  "mise": {
    "fileMatch": [
      "^packages/.config/mise/config\\.toml$"
    ]
  },
  "packageRules": [
    {
      "description": "Wait 14 days before updating to avoid supply chain attacks",
      "matchUpdateTypes": ["major", "minor", "patch", "pin", "digest"],
      "stabilityDays": 14
    },
    {
      "description": "Security updates bypass stability period for immediate patching",
      "matchUpdateTypes": ["security"],
      "stabilityDays": 0
    },
    {
      "description": "Enable digest pinning for GitHub Actions",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "description": "Group GitHub Actions updates into one PR",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "schedule": ["every weekend"]
    },
    {
      "description": "Group all Neovim plugin updates into one PR",
      "matchManagers": ["regex"],
      "matchFileNames": ["nvim/.config/nvim/lua/**/*.lua"],
      "groupName": "neovim plugins",
      "schedule": ["every weekend"]
    },
    {
      "description": "Group mise tool updates into one PR",
      "matchManagers": ["mise"],
      "matchFileNames": ["packages/.config/mise/config.toml"],
      "groupName": "mise tools",
      "schedule": ["every weekend"]
    },
    {
      "description": "Group Dockerfile dependency updates into one PR",
      "matchManagers": ["regex"],
      "matchFileNames": ["Dockerfile"],
      "groupName": "dockerfile dependencies",
      "schedule": ["every weekend"]
    }
  ]
}
